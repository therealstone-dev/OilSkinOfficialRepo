{% extends 'components/boostrap/layout_boostrap.jinja' %}

{% block title %}{{ category_name }} - OilSkin{% endblock %}

{% block content %}

<main class="min-vh-100 w-100"
      style="background: linear-gradient(rgba(0,0,0,0.8),rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/fondo_2.png') }}') center/cover no-repeat fixed;">

    <!-- HEADER -->
    <section class="container text-center py-5 text-white">
        <h1 class="display-5 fw-bold mb-3">{{ category_name }}</h1>
        <p class="text-light">{{ descripcion }}</p>

        <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
            {% if productos %}
            <span class="badge bg-light text-dark">
                {{ productos|length }} Productos encontrados
            </span>
            {% endif %}
            <span class="badge bg-secondary">100% Orgánico</span>
            <span class="badge bg-secondary">Piel Renovada</span>
        </div>
    </section>

    <!-- PRODUCTOS -->
    {% if productos %}
    <div class="container pb-5">
        <div class="row g-4 justify-content-center">

            {% for p in productos %}
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 text-center bg-dark text-white border-0 shadow">

                    <div class="pt-4">
                        <img src="{{ url_for('static', filename='img/logo.png') }}"
                             class="rounded-circle border"
                             style="width:120px; height:120px; object-fit:cover;">
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold">{{ p.nombre_producto }}</h5>

                        <p class="text-secondary small flex-grow-1">
                            {{ p.descripcion }}
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold text-warning">
                                ${{ "%.2f"|format(p.precio) }}
                            </span>

                            <a href="{{ url_for('main_blueprint.get_product', id=p.id_producto) }}"
                               class="btn btn-sm fw-bold"
                               style="background:#CEB06E; color:black;">
                                Ver
                            </a>
                        </div>
                    </div>

                </div>
            </div>
            {% endfor %}

        </div>
    </div>

    {% else %}
    <div class="container text-center py-5 text-white">
        <p>No hay productos disponibles en esta categoría.</p>
    </div>
    {% endif %}

</main>

{% endblock %}