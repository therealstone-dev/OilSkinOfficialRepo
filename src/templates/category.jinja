{% extends 'layout.jinja' %}

{% block title %}{{ category_name }} - OilSkin{% endblock %}

{% block content %}
<main class="min-vh-100 w-100"
    style="margin: 0; padding: 0; width: 100vw; background-image: linear-gradient(rgba(0,0,0,0.8),rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/fondo_2.png') }}'); background-size: cover; background-repeat: no-repeat; background-position: center; background-attachment: fixed;">

    <style>
        main {
            margin: 0 !important;
            padding: 0 !important;
        }
    </style>

    <section class="w-100 px-3 px-md-4 pt-5 pb-4 text-center">
        <h1 class="display-4 fw-bold text-white mb-3">
            {{ category_name }}
        </h1>
        <p class="text-light fs-6 lh-lg">
            {{ descripcion }}
        </p>
        <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
            {% if productos %}
            <span class="badge rounded-pill text-light" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                {{ productos|length }} Productos encontrados
            </span>
            {% endif %}
            <span class="badge rounded-pill text-light" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                100% Orgánico
            </span>
            <span class="badge rounded-pill text-light" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                Piel Renovada
            </span>
        </div>
    </section>

    {% if productos %}
    <div class="w-100 px-3 px-md-4 pb-5">
        <div class="row g-4 mx-auto" style="max-width: 80rem;">
            {% for p in productos %}
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card border-0 h-100 transition cursor-pointer" style="background-color: rgba(0,0,0,0.4); border: 2px solid rgba(255,255,255,0.1);">
                    <div class="card-body d-flex flex-column">
                        <div class="text-center mb-3">
                            <img 
                                src="{{ url_for('static', filename='img/logo.png') }}" 
                                alt="{{ p.nombre_producto }}" 
                                class="rounded-circle border" style="width: 160px; height: 160px; object-fit: cover; border-color: rgba(206, 176, 110, 0.2);"
                            >
                        </div>
                        <div class="text-center">
                            <h2 class="fs-6 fw-bold text-white text-truncate">{{ p.nombre_producto }}</h2>
                            <p class="mt-2 small text-light fst-italic" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;">{{ p.descripcion }}</p>
                            <div class="mt-3 d-flex align-items-center justify-content-between gap-2">
                                <span class="fs-6 fw-bold" style="color: #CEB06E;">${{ "%.2f"|format(p.precio) }}</span>
                                <a href="{{ url_for('main_blueprint.get_product', id=p.id_producto) }}"
                                   class="btn btn-sm fw-bold text-black rounded-pill transition" style="background-color: #CEB06E;">
                                    Añadir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="w-100 px-3 px-md-4 py-5 text-center">
        <p class="text-light fs-6">No hay productos disponibles en esta categoría.</p>
    </div>
    {% endif %}
</main>
{% endblock %}