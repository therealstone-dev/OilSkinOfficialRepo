{% extends 'layout.jinja' %}

{% block title %}Error - OilSkin{% endblock %}

{% block content %}
<main class="min-vh-100 d-flex align-items-center justify-content-center px-3" style="background: linear-gradient(to bottom right, rgba(254, 240, 243), rgba(254, 228, 208));">
    <div class="card border-0 shadow-lg p-5" style="max-width: 500px; width: 100%;">
        <div class="mb-4">
            <svg class="d-block mx-auto text-danger" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>

        <!-- Mensaje de error -->
        <h1 class="fs-3 fw-bold text-muted mb-2 text-center">¡Oops!</h1>
        <p class="fs-6 text-muted mb-4 text-center">
                Algo salió mal. Por favor intenta nuevamente. ({{ mensaje }})
        </p>

        <!-- Botones de acción -->
        <div class="d-flex flex-column gap-2">
            <a href="{{ url_for('main_blueprint.index') }}" 
               class="btn text-black fw-bold py-3 px-4 rounded-2" style="background-color: #CEB06E;">
                Volver al Inicio
            </a>
            <a href="javascript:history.back()" 
               class="btn border-2 text-muted fw-bold py-3 px-4 rounded-2">
                Atrás
            </a>
        </div>
    </div>
</main>
{% endblock %}
