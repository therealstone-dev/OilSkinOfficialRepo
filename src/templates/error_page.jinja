{% extends 'components/boostrap/layout_boostrap.jinja' %}

{% block title %}Error - OilSkin{% endblock %}

{% block content %}

<main class="min-vh-100 d-flex align-items-center justify-content-center px-3"
      style="background: linear-gradient(to bottom right, #fef2f2, #fff7ed);">

    <div class="card shadow text-center p-4" style="max-width: 400px; width:100%;">

        <!-- ICONO -->
        <div class="mb-4">
            <i class="fa-solid fa-circle-exclamation fa-4x text-danger"></i>
        </div>

        <!-- MENSAJE -->
        <h1 class="fw-bold mb-2">¡Oops!</h1>
        <p class="text-muted fs-5 mb-4">
            Algo salió mal. Por favor intenta nuevamente. ({{ mensaje }})
        </p>

        <!-- BOTONES -->
        <div class="d-grid gap-2">

            <a href="{{ url_for('main_blueprint.index') }}"
               class="btn fw-bold"
               style="background:#CEB06E; color:black;">
                Volver al Inicio
            </a>

            <a href="javascript:history.back()"
               class="btn btn-outline-secondary fw-bold">
                Atrás
            </a>

        </div>

    </div>

</main>

{% endblock %}