{% extends 'components/boostrap/layout_boostrap.jinja' %}

{% block title %}Sobre OilSkin{% endblock %}

{% block content %}

<header style="background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/publicidad.jpg') }}') center/cover no-repeat;">
    <div class="container py-4 text-center">
        <img src="{{ url_for('static', filename='img/logo.png') }}"
             class="rounded-circle"
             style="width:100px; height:100px; object-fit:cover;">
    </div>
</header>

<main class="bg-light rounded">

    <!-- INFO -->
    <div class="container my-5">
        <div class="bg-white rounded-4 p-5 shadow">

            <h1 class="display-5 fw-bold text-center mb-5">
                OIL SKIN: <span class="text-secondary">Esencia Natural</span>, Resultados Reales
            </h1>

            <div class="row g-4">

                <!-- CARD 1 -->
                <div class="col-lg-4">
                    <div class="h-100 bg-secondary text-white p-4 rounded-4 shadow-sm">
                        <h2 class="fw-bold mb-3">Descubre LUMINEA</h2>
                        <p>
                            Nuestro <span class="text-success fw-semibold">Tónico Facial LUMINEA</span> revitaliza tu piel al instante.
                        </p>

                        <h5 class="mt-4">¿Por qué es extraordinario?</h5>
                        <ul class="list-unstyled mt-3">
                            <li class="mb-2">
                                <i class="fa-solid fa-check text-success me-2"></i>
                                <strong>Vitalidad:</strong> Refresca en segundos
                            </li>
                            <li>
                                <i class="fa-solid fa-check text-success me-2"></i>
                                <strong>Hidratación:</strong> Sin sensación grasa
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- CARD 2 -->
                <div class="col-lg-4">
                    <div class="h-100 bg-light p-4 rounded-4 shadow-sm border">
                        <h2 class="h4 text-success">Nuestra Esencia</h2>
                        <p class="text-muted">
                            En <strong>OIL SKIN</strong>, redefinimos el cuidado personal desde Bogotá, Colombia.
                        </p>
                        <p class="text-muted border-top pt-3">
                            Creamos soluciones conscientes, éticas y efectivas.
                        </p>
                    </div>
                </div>

                <!-- CARD 3 -->
                <div class="col-lg-4">
                    <div class="h-100 bg-secondary text-white p-4 rounded-4 shadow">
                        <h2 class="fw-bold mb-3">Nuestra Misión</h2>
                        <p>
                            Creamos fórmulas naturales que regeneran la piel respetando el medio ambiente.
                        </p>
                        <div class="border-start border-4 border-success ps-3 mt-3">
                            <small class="fst-italic">
                                "Cosmética honesta y sostenible."
                            </small>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- EQUIPO -->
    <div class="text-center py-4">
        <h2 class="fw-bold">Equipo de Trabajo</h2>
    </div>

    <div class="container mb-5">
        <div class="bg-white rounded-4 p-4 shadow">

            <h3 class="text-center mb-4">La familia</h3>

            <div class="row g-4 justify-content-center">

                <!-- PERSONA -->
                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <img src="{{ url_for('static', filename='img/team-program-1.jpg') }}"
                             class="img-fluid rounded mb-3"
                             style="height:250px; object-fit:cover;">
                        <h5>David Lombana</h5>
                        <p class="text-muted">Analista Principal</p>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <img src="{{ url_for('static', filename='img/team-program-2.jpg') }}"
                             class="img-fluid rounded mb-3"
                             style="height:250px; object-fit:cover;">
                        <h5>Jesus Barrios</h5>
                        <p class="text-muted">Programador</p>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <img src="{{ url_for('static', filename='img/team-program-3.jpg') }}"
                             class="img-fluid rounded mb-3"
                             style="height:250px; object-fit:cover;">
                        <h5>Camilo Aroca</h5>
                        <p class="text-muted">Programador</p>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <img src="{{ url_for('static', filename='img/team-program-4.jpg') }}"
                             class="img-fluid rounded mb-3"
                             style="height:250px; object-fit:cover;">
                        <h5>Jader Rico</h5>
                        <p class="text-muted">Diseñador</p>
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <img src="{{ url_for('static', filename='img/team-program-5.jpg') }}"
                             class="img-fluid rounded mb-3"
                             style="height:250px; object-fit:cover;">
                        <h5>Angie Contreras</h5>
                        <p class="text-muted">Diseñadora</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

</main>

{% endblock %}