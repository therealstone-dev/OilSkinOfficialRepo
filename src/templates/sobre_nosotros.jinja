{% extends 'layout.jinja' %}

{% block title %}Sobre OilSkin{% endblock %}

{% block content %}
<header
    style="background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/publicidad.jpg') }}'); background-size: cover; background-repeat: no-repeat; background-position: center;">
    <div class="d-flex flex-row justify-content-center shadow-lg align-items-center gap-4 py-4">
        <img src="{{ url_for('static', filename='img/logo.png') }}" alt="OIL SKIN Logo"
            class="rounded-circle" style="width: 96px; height: 96px; object-fit: cover;">
    </div>
</header>
<main class="bg-secondary rounded">

    <div class="bg-white rounded-5 m-4">
        <section class="mx-auto px-3 py-5 text-body">
            <h1 class="display-5 fw-bold text-center mb-5 tracking-tight">
                OIL SKIN: <span class="text-secondary">Esencia Natural</span>, Resultados Reales
            </h1>


            <div class="row g-4 align-items-start">
                <div
                    class="col-12 col-md-4 text-white d-flex flex-column gap-3 p-4 rounded-5 border" style="background-color: #495057;">
                    <div>
                        <h2 class="fs-4 fw-bold mb-3">Descubre LUMINEA</h2>
                        <p class="lh-lg mb-3">
                            Nuestro <span class="fst-italic text-success fw-medium">Tónico Facial LUMINEA</span> es
                            más que un
                            paso en tu rutina: es una experiencia de revitalización inmediata.
                        </p>
                    </div>

                    <div class="gap-3">
                        <h3 class="fs-6 fw-bold text-uppercase tracking-wide">¿Por qué es extraordinario?
                        </h3>
                        <ul class="list-unstyled gap-3">
                            <li class="d-flex gap-2">
                                <span class="text-success">✓</span>
                                <p><strong>Vitalidad Instantánea:</strong> Tonifica y refresca en segundos.</p>
                            </li>
                            <li class="d-flex gap-2">
                                <span class="text-success">✓</span>
                                <p><strong>Hidratación Inteligente:</strong> Sin sensación grasa ni pesada.</p>
                            </li>
                        </ul>
                    </div>
                </div>

                <div
                    class="col-12 col-md-4 d-flex flex-column gap-3 p-4 rounded-5 border" style="background-color: #f8f9fa;">
                    <h2 class="fs-5 fw-semibold text-success">Nuestra Esencia</h2>
                    <p class="lh-lg text-muted">
                        En <span class="fw-bold">OIL SKIN</span>, redefinimos el cuidado personal desde el corazón de
                        Bogotá,
                        Colombia. Somos una marca comprometida con la cosmética de alta gama, fusionando la pureza
                        natural con
                        procesos sostenibles.
                    </p>
                    <p class="lh-lg text-muted border-top pt-3">
                        Gestionamos cada detalle para llevar a todo el país soluciones de belleza conscientes, éticas y
                        altamente
                        efectivas.
                    </p>
                </div>


                <div
                    class="col-12 col-md-4 text-white p-4 rounded-5 shadow" style="background-color: #495057;">
                    <h2 class="fs-5 fw-bold mb-3">Nuestra Misión</h2>
                    <p class="lh-lg" style="opacity: 0.9; margin-bottom: 1.5rem;">
                        Nuestra razón de ser es tu bienestar. Creamos fórmulas eficaces que regeneran la piel de forma
                        natural,
                        respetando siempre el equilibrio del medio ambiente para mantenerlo hasta los años venideros y
                        ofrecer
                        productos.
                    </p>
                    <div class="border-start ps-3" style="border-color: rgba(52, 211, 153, 0.5) !important;">
                        <p class="small fst-italic">"Cosmética honesta, sostenible y diseñada para resaltar tu mejor
                            versión."</p>
                    </div>
                </div>

            </div>
        </section>
    </div>
    <div class="d-flex flex-row justify-content-center align-items-center gap-5 py-5">
        <h1 class="fs-2 fw-bold text-muted">Equipo de Trabajo</h1>
    </div>
    <div class="bg-white rounded-5 m-4">
        <h1 class="fs-2 text-center pt-3">La familia</h1>
        <div class="d-flex flex-wrap justify-content-center p-4 gap-5">
            <div
                class="d-flex flex-column align-items-center rounded-3 p-4 shadow transition cursor-pointer" style="transition: all 0.3s ease;">
                <img src="{{ url_for('static', filename='img/team-program-1.jpg') }}"
                    class="rounded-3" style="width: 256px; height: 256px; object-fit: cover; margin-bottom: 1rem;" alt="David Lombana">
                <p class="text-center fs-5 fw-medium text-muted">David Lombana</p>
                <p class="text-center text-muted">Analista Principal</p>
            </div>
            <div
                class="flex flex-col items-center rounded-xl p-8 shadow-md transition-all duration-300 ease-in-out hover:bg-gray-100 hover:rounded-2xl hover:shadow-lg hover:-translate-y-1 cursor-pointer">
                <img src="{{ url_for('static', filename='img/team-program-2.jpg') }}"
                    class="w-64 h-64 rounded-lg object-cover mb-4" alt="Jesus Barrios">
                <p class="text-center text-2xl font-medium text-gray-700 leading-snug">Jesus Barrios</p>
                <p class="text-center text-lg text-gray-400">Programador</p>
            </div>
            <div
                class="flex flex-col items-center rounded-xl p-8 shadow-md transition-all duration-300 ease-in-out hover:bg-gray-100 hover:rounded-2xl hover:shadow-lg hover:-translate-y-1 cursor-pointer">
                <img src="{{ url_for('static', filename='img/team-program-3.jpg') }}"
                    class="w-64 h-64 rounded-lg object-cover mb-4" alt="Camilo Aroca">
                <p class="text-center text-2xl font-medium text-gray-700 leading-snug">Camilo Aroca</p>
                <p class="text-center text-lg text-gray-400">Programador</p>
            </div>
            <div
                class="flex flex-col items-center rounded-xl p-8 shadow-md transition-all duration-300 ease-in-out hover:bg-gray-100 hover:rounded-2xl hover:shadow-lg hover:-translate-y-1 cursor-pointer">
                <img src="{{ url_for('static', filename='img/team-program-4.jpg') }}"
                    class="w-64 h-64 rounded-lg object-cover mb-4" alt="Jader Rico">
                <p class="text-center text-2xl font-medium text-gray-700 leading-snug">Jader Rico</p>
                <p class="text-center text-lg text-gray-400">Diseñador</p>
            </div>
            <div
                class="flex flex-col items-center rounded-xl p-8 shadow-md transition-all duration-300 ease-in-out hover:bg-gray-100 hover:rounded-2xl hover:shadow-lg hover:-translate-y-1 cursor-pointer">
                <img src="{{ url_for('static', filename='img/team-program-5.jpg') }}"
                    class="w-64 h-64 rounded-lg object-cover mb-4" alt="Angie Contreras">
                <p class="text-center text-2xl font-medium text-gray-700 leading-snug">Angie Contreras</p>
                <p class="text-center text-lg text-gray-400">Diseñadora</p>
            </div>
        </div>
    </div>
</main>
{% endblock %}