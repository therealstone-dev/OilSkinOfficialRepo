{% extends 'components/boostrap/layout_boostrap.jinja' %}

{% block title %}Inicio - OilSkin{% endblock %}

{% block content %}

<header style="background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/fondo_2.png') }}') center/cover no-repeat;">
    <div class="container py-5">
        <div class="row align-items-center justify-content-center g-4 text-center text-lg-start">

            <div class="col-lg-auto">
                <img src="{{ url_for('static', filename='img/logo.png') }}"
                     class="rounded-circle img-fluid"
                     style="width:160px; height:160px; object-fit:cover;">
            </div>

            <div class="col-lg-6 text-white">
                <h1 class="display-3 fw-bold">OIL SKIN</h1>
                <p class="lead text-light">
                    Lorem ipsum dolor sit amet consectetur adipisicing elit. Aliquid numquam asperiores eligendi cupiditate.
                </p>
                <a href="#" class="btn fw-bold px-4 py-2"
                   style="background:#CEB06E; color:black;">
                    ¡Explora nuestros productos!
                </a>
            </div>

        </div>
    </div>
</header>

<main style="background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/palmas.png') }}') center/cover no-repeat;">

    <!-- FEATURES -->
    <section class="py-5" style="background:#0a0a0a;">
        <div class="container">

            <div class="row text-center g-5">

                <!-- ITEM -->
                <div class="col-md-6 col-lg-3 text-white">
                    <div class="p-3 border rounded-circle d-inline-block mb-3" style="border-color:#d4af37;">
                        <i class="fa-solid fa-leaf fa-2x text-warning"></i>
                    </div>
                    <h5>100% Orgánico</h5>
                    <p class="text-secondary small">Ingredientes naturales sin químicos agresivos.</p>
                </div>

                <div class="col-md-6 col-lg-3 text-white">
                    <div class="p-3 border rounded-circle d-inline-block mb-3" style="border-color:#d4af37;">
                        <i class="fa-solid fa-droplet fa-2x text-warning"></i>
                    </div>
                    <h5>Nutrición Intensa</h5>
                    <p class="text-secondary small">Hidratación profunda todo el día.</p>
                </div>

                <div class="col-md-6 col-lg-3 text-white">
                    <div class="p-3 border rounded-circle d-inline-block mb-3" style="border-color:#d4af37;">
                        <i class="fa-solid fa-star fa-2x text-warning"></i>
                    </div>
                    <h5>Efecto Glow</h5>
                    <p class="text-secondary small">Piel radiante y rejuvenecida.</p>
                </div>

                <div class="col-md-6 col-lg-3 text-white">
                    <div class="p-3 border rounded-circle d-inline-block mb-3" style="border-color:#d4af37;">
                        <i class="fa-solid fa-shield-halved fa-2x text-warning"></i>
                    </div>
                    <h5>Testeado</h5>
                    <p class="text-secondary small">Seguro para todo tipo de piel.</p>
                </div>

            </div>

            <!-- TITLE -->
            <h2 class="text-center text-white fw-bold my-5 display-5">
                <u>Nuestra Empresa</u>
            </h2>

            <!-- BLOCK 1 -->
            <div class="row align-items-center bg-white bg-opacity-10 rounded p-4 mb-4 backdrop-blur">

                <div class="col-md-4 text-center text-white">
                    <img src="{{ url_for('static', filename='img/publicidad.jpg') }}"
                         class="rounded-circle img-fluid mb-3"
                         style="width:150px; height:150px; object-fit:cover;">
                    <h5>Ingredientes <span class="text-warning">Naturales</span></h5>
                </div>

                <div class="col-md-8 text-white">
                    <p class="fs-5 border-start ps-3" style="border-color:#d4af37;">
                        Aceites <strong class="text-warning">100% orgánicos</strong>, sin químicos agresivos.
                    </p>
                </div>

            </div>

            <!-- BLOCK 2 -->
            <div class="row align-items-center bg-white bg-opacity-10 rounded p-4 mb-4">

                <div class="col-md-8 text-white">
                    <p class="fs-5 border-end pe-3 text-end" style="border-color:#d4af37;">
                        Aceites de <strong class="text-warning">nutrición intensa</strong>, que protegen tu piel.
                    </p>
                </div>

                <div class="col-md-4 text-center text-white">
                    <img src="{{ url_for('static', filename='img/publicidad.jpg') }}"
                         class="rounded-circle img-fluid mb-3"
                         style="width:150px; height:150px; object-fit:cover;">
                    <h5>Cuidado <span class="text-warning">Profundo</span></h5>
                </div>

            </div>

            <!-- BLOCK 3 -->
            <div class="row align-items-center bg-white bg-opacity-10 rounded p-4">

                <div class="col-md-4 text-center text-white">
                    <img src="{{ url_for('static', filename='img/publicidad.jpg') }}"
                         class="rounded-circle img-fluid mb-3"
                         style="width:150px; height:150px; object-fit:cover;">
                    <h5>Resultados <span class="text-warning">Visibles</span></h5>
                </div>

                <div class="col-md-8 text-white">
                    <p class="fs-5 border-start ps-3" style="border-color:#d4af37;">
                        Piel más suave, firme y luminosa en semanas.
                    </p>
                </div>

            </div>

        </div>
    </section>

</main>

{% endblock %}