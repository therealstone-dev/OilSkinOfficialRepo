{% extends 'layout.jinja' %}

{% block title %}Inicio - OilSkin{% endblock %}

{% block content %}

<header
    style="background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/fondo_2.png') }}'); background-size: cover; background-repeat: no-repeat; background-position: center;">
    <div class="d-flex flex-column flex-lg-row justify-content-center align-items-center gap-4 py-5 px-3">
        <img src="{{ url_for('static', filename='img/logo.png') }}" alt="OIL SKIN Logo"
            style="width: 160px; height: 160px;" class="rounded-pill object-cover">
        <div class="d-flex flex-column gap-3 text-center text-lg-start">
            <h1 class="display-3 fw-bold text-white">OIL SKIN</h1>
            <p class="text-muted lh-lg" style="max-width: 350px;">Lorem ipsum dolor sit amet
                consectetur
                adipisicing elit. Aliquid numquam asperiores eligendi cupiditate delectus at debitis dignissimos
                minima
                aperiam aliquam quas ratione saepe quasi, necessitatibus iste? Molestias id odio accusantium?</p>
            <a href="#"
                class="btn text-center text-black fw-bold py-3 px-5 rounded-pill transition" style="background-color: #CEB06E;">¡Explora
                nuestros productos!</a>
        </div>
    </div>
</header>
<main
    style="background-image: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('{{ url_for('static', filename='img/palmas.png') }}'); background-size: cover; background-repeat: no-repeat; background-position: center;">
    <section style="background-color: #0a0a0a;" class="py-5 px-3">
        <article>
            <div class="container-lg">

                <div class="row g-4 text-center">

                    <div class="col-12 col-md-6 col-lg-3 d-flex flex-column align-items-center gap-3">
                        <div
                            class="p-3 rounded-circle border"
                            style="border-color: rgba(217, 119, 6, 0.3); background-color: rgba(217, 119, 6, 0.05);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path
                                    d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8h-5a7 7 0 0 1-7 7Z" />
                                <path d="M7 21h10" />
                            </svg>
                        </div>
                        <h3 class="fs-5 fw-semibold text-white">100% Orgánico</h3>
                        <p class="text-muted small lh-sm">
                            Ingredientes naturales seleccionados de cultivos sostenibles, sin químicos agresivos.
                        </p>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3 d-flex flex-column align-items-center gap-3">
                        <div
                            class="p-3 rounded-circle border"
                            style="border-color: rgba(217, 119, 6, 0.3); background-color: rgba(217, 119, 6, 0.05);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path
                                    d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z" />
                            </svg>
                        </div>
                        <h3 class="fs-5 fw-semibold text-white">Nutrición Intensa</h3>
                        <p class="text-muted small lh-sm">
                            Restaura la barrera natural de tu piel con una hidratación que dura todo el día.
                        </p>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3 d-flex flex-column align-items-center gap-3">
                        <div
                            class="p-3 rounded-circle border"
                            style="border-color: rgba(217, 119, 6, 0.3); background-color: rgba(217, 119, 6, 0.05);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path
                                    d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" />
                            </svg>
                        </div>
                        <h3 class="fs-5 fw-semibold text-white">Efecto Glow</h3>
                        <p class="text-muted small lh-sm">
                            Luce una piel radiante y rejuvenecida gracias a nuestra fórmula de absorción rápida.
                        </p>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3 d-flex flex-column align-items-center gap-3">
                        <div
                            class="p-3 rounded-circle border"
                            style="border-color: rgba(217, 119, 6, 0.3); background-color: rgba(217, 119, 6, 0.05);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                                fill="none" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                            </svg>
                        </div>
                        <h3 class="fs-5 fw-semibold text-white">Dermatológicamente Testeado</h3>
                        <p class="text-muted small lh-sm">
                            Fórmulas seguras para todo tipo de piel, incluso las más sensibles.
                        </p>
                    </div>
                </div>
            </div>
        </article>
        <h1 class="text-white text-center my-5 display-2 fw-bold text-decoration-underline">Nuestra Empresa</h1>
        <article class="w-100 px-3">
            <div class="d-flex flex-column align-items-center py-5 gap-3">


                <div
                    class="d-flex flex-row justify-content-between align-items-center py-5 px-5 rounded-3 w-100" style="background-color: rgba(255,255,255,0.1); max-width: 60rem; border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);">

                    <div class="d-flex flex-column align-items-center flex-shrink-0">
                        <div class="p-2 rounded-circle" style="background: linear-gradient(to bottom, rgba(234, 179, 8, 0.5), transparent);">
                            <img class="rounded-circle shadow-lg" style="width: 13rem; height: 13rem; object-fit: cover; display: none;" width="180" height="180"
                                src="{{ url_for('static', filename='img/publicidad.jpg') }}" alt="Ingredientes">
                        </div>
                        <h2 class="fs-5 text-center text-white fw-bold mt-4 lh-sm">
                            Ingredientes <span class="text-warning">Naturales</span>
                        </h2>
                    </div>

                    <div class="flex-grow-1 ms-5">
                        <p class="text-white fs-5 lh-lg" style="border-left: 2px solid rgba(217, 119, 6, 0.3); padding-left: 2rem;">
                            Aceites <span class="fw-bold text-warning">100% orgánicos</span>, seleccionados
                            artesanalmente para garantizar pureza total sin químicos agresivos.
                        </p>
                    </div>

                </div>
                <div
                    class="d-flex flex-row justify-content-between align-items-center py-5 px-5 rounded-3 w-100" style="background-color: rgba(255,255,255,0.1); max-width: 60rem; border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);">

                    <div class="flex-grow-1 me-5">
                        <p class="text-white fs-5 lh-lg" style="border-right: 2px solid rgba(217, 119, 6, 0.3); padding-right: 3rem;">
                            Aceites de <span class="fw-bold text-warning">Nutrición intensa</span>, que restauran la barrera cutánea y protegen tu piel.
                        </p>
                    </div>

                    <div class="d-flex flex-column align-items-center flex-shrink-0">
                        <div class="p-2 rounded-circle" style="background: linear-gradient(to bottom, rgba(234, 179, 8, 0.5), transparent);">
                            <img class="rounded-circle shadow-lg" style="width: 13rem; height: 13rem; object-fit: cover; display: none;" width="180" height="180"
                                src="{{ url_for('static', filename='img/publicidad.jpg') }}" alt="Cuidado">
                        </div>
                        <h2 class="fs-5 text-center text-white fw-bold mt-4 lh-sm">
                            Cuidado <span class="text-warning">Profundo</span>
                        </h2>
                    </div>

                </div>
                <div
                    class="d-flex flex-row justify-content-between align-items-center py-5 px-5 rounded-3 w-100" style="background-color: rgba(255,255,255,0.1); max-width: 60rem; border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);">

                    <div class="d-flex flex-column align-items-center flex-shrink-0">
                        <div class="p-2 rounded-circle" style="background: linear-gradient(to bottom, rgba(234, 179, 8, 0.5), transparent);">
                            <img class="rounded-circle shadow-lg" style="width: 13rem; height: 13rem; object-fit: cover; display: none;" width="180" height="180"
                                src="{{ url_for('static', filename='img/publicidad.jpg') }}" alt="Resultados">
                        </div>
                        <h2 class="fs-5 text-center text-white fw-bold mt-4 lh-sm">
                            Resultados <span class="text-warning">Visibles</span>
                        </h2>
                    </div>

                    <div class="flex-grow-1 ms-5">
                        <p class="text-white fs-5 lh-lg" style="border-left: 2px solid rgba(217, 119, 6, 0.3); padding-left: 2rem;">
                            Piel más suave, firme y luminosa en semanas. Observa resultados duraderos y en poco tiempo.
                        </p>
                    </div>

                </div>  
            </div>
        </article>
    </section>

</main>
{% endblock %}