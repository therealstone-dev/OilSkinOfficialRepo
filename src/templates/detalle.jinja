<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ producto.nombre_producto }} - OIlSkin</title>
    <link href="{{ url_for('static', filename='css/style.css') }}" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <div class="max-w-3xl mx-auto py-12 px-4">
        <div class="bg-white rounded-lg shadow-lg p-8">
            <h1 class="text-5xl font-bold text-gray-800 mb-4">{{ producto.nombre_producto }}</h1>
            <p class="text-xl text-gray-600 mb-6">{{ producto.descripcion }}</p>
            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6">
                <p class="text-lg text-gray-700"><strong>Precio:</strong> ${{ producto.precio }}</p>
                <p class="text-lg text-gray-700"><strong>Stock:</strong> {{ producto.stock }} unidades</p>
            </div>
            <a href="/" class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-6 rounded transition duration-200">
                ← Volver a productos
            </a>
        </div>
    </div>
</body>
</html>
