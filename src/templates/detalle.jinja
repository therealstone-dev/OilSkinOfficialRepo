<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ producto.nombre_producto }} - OIlSkin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="{{ url_for('static', filename='css/style.css') }}" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="card border-0 shadow-lg p-5">
            <h1 class="display-5 fw-bold text-muted mb-3">{{ producto.nombre_producto }}</h1>
            <p class="fs-5 text-muted mb-4">{{ producto.descripcion }}</p>
            <div class="alert alert-info border-start border-5 mb-4">
                <p class="fs-6 text-muted mb-2"><strong>Precio:</strong> ${{ producto.precio }}</p>
                <p class="fs-6 text-muted"><strong>Stock:</strong> {{ producto.stock }} unidades</p>
            </div>
            <a href="/" class="btn btn-primary fw-bold py-3 px-4">
                ← Volver a productos
            </a>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
